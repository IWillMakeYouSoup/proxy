{
  "name": "proxy-server",
  "version": "1.0.0",
  "description": "Transparent HTTP proxy with logging, modification, and mock support",
  "type": "module",
  "main": "src/server.ts",
  "scripts": {
    "dev:proxy": "tsx watch src/server.ts",
    "dev:web-api": "tsx watch web/server/index.ts",
    "dev:web-client": "vite --config web/client/vite.config.ts",
    "dev": "concurrently -n proxy,api,web -c blue,green,magenta \"npm:dev:proxy\" \"npm:dev:web-api\" \"npm:dev:web-client\"",
    "start:proxy": "tsx src/server.ts",
    "start:web-api": "tsx web/server/index.ts",
    "start:web-client": "vite --config web/client/vite.config.ts",
    "start": "concurrently -n proxy,api,web -c blue,green,magenta \"npm:start:proxy\" \"npm:start:web-api\" \"npm:start:web-client\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build:client": "vite build --config web/client/vite.config.ts",
    "build": "npm run typecheck && npm run build:client"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "chokidar": "^3.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0"
  }
}
